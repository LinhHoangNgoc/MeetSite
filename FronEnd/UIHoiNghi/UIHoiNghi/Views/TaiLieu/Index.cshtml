@{ ViewBag.Active = "tailieu"; ViewData["Title"] = "Tài liệu"; }

<div class="meet-page-head">
    <h2><i class="fa-solid fa-folder-open"></i> Tài liệu hội nghị</h2>
    <div class="sub">Tải lên, phân quyền theo nhóm và chia sẻ tài liệu cho đại biểu bằng mã QR.</div>
</div>

<div class="meet-toolbar">
    <button class="btn-meet" id="btnUpload"><i class="fa-solid fa-cloud-arrow-up"></i> Tải tài liệu lên</button>
    <button class="btn-meet warn" id="btnQuyen"><i class="fa-solid fa-user-lock"></i> Phân quyền</button>
    <button class="btn-meet sec" id="btnQR"><i class="fa-solid fa-qrcode"></i> QR chia sẻ</button>
    <button class="btn-meet ghost" id="btnDown"><i class="fa-solid fa-download"></i> Tải về</button>
    <button class="btn-meet danger" id="btnDel"><i class="fa-solid fa-trash"></i> Xóa</button>
</div>

<div id="gridTaiLieu" class="meet-grid-wrap"></div>

<script src="/Script/qrCode/qrcode.min.js"></script>
<script src="/Script/meet_tailieu.js?v=1"></script>
