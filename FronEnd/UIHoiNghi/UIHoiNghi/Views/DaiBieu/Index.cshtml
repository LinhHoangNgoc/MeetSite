@{ ViewBag.Active = "daibieu"; ViewData["Title"] = "Đại biểu"; }

<div class="meet-page-head">
    <h2><i class="fa-solid fa-user-group"></i> Đại biểu</h2>
    <div class="sub">Quản lý danh sách đại biểu, phân nhóm, gắn nhãn VIP và sinh mã QR cá nhân.</div>
</div>

<div class="meet-toolbar">
    <button class="btn-meet" id="btnAddDB"><i class="fa-solid fa-user-plus"></i> Thêm đại biểu</button>
    <button class="btn-meet warn" id="btnEditDB"><i class="fa-solid fa-pen"></i> Sửa</button>
    <button class="btn-meet danger" id="btnDelDB"><i class="fa-solid fa-trash"></i> Xóa</button>
    <button class="btn-meet sec" id="btnQR"><i class="fa-solid fa-qrcode"></i> Xem / In QR</button>
    <button class="btn-meet ghost" id="btnImport"><i class="fa-solid fa-file-import"></i> Nhập nhanh</button>
    <button class="btn-meet ghost" id="btnNhom"><i class="fa-solid fa-layer-group"></i> Quản lý nhóm</button>
    <span class="meet-spacer"></span>
    <select id="filterNhom" style="min-width:160px"></select>
</div>

<div id="gridDaiBieu" class="meet-grid-wrap"></div>

<script src="/Script/qrCode/qrcode.min.js"></script>
<script src="/Script/meet_daibieu.js?v=1"></script>
