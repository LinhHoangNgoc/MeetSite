@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

@await Html.PartialAsync("~/Views/Shared/Partial/DoiMatKhau.cshtml")
<div style="width:100%;float:left">
    <div style="width:100%;float:left" id="divHeader">
        @await Html.PartialAsync("~/Views/Shared/Partial/Header.cshtml")
    </div>
    <div style="width:250px;float:left" id="divMenu">
        <table style="width:100%;" cellpadding="0" cellspacing="0" id="tabMenu">
        </table>
    </div>
    <div style="width:calc(100% - 250px);float:right;padding:0px" id="divBody">
        @RenderBody()
    </div>
    <div style="width:100%;float:left" id="divFooter">
        @await Html.PartialAsync("~/Views/Shared/Partial/Footer.cshtml")
    </div>
</div>
