@{
    ViewData["Title"] = "Quản lý Hội nghị ITKA";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    var hdUser = Context.Session.GetString("HoTen");
    if (string.IsNullOrEmpty(hdUser)) hdUser = Context.Session.GetString("TenDangNhap");
    var hdIsAdmin = false;
    var hdAdminRaw = Context.Session.GetString("Admin");
    if (!string.IsNullOrEmpty(hdAdminRaw)) bool.TryParse(hdAdminRaw, out hdIsAdmin);
}
<link href="/Css/home-desktop.css?v=35" rel="stylesheet" />
@await Html.PartialAsync("~/Views/Shared/Partial/DoiMatKhau.cshtml")

<div class="wd-desktop" id="wdDesktop">
    <div class="wd-grid" id="wdGrid"></div>
    <div class="wd-icons" id="wdIcons"></div>
    <div class="wd-widgets" id="wdWidgets"></div>
    <div class="wd-windows" id="wdWindows"></div>
</div>

<div class="wd-taskbar" id="wdTaskbar">
    <button class="wd-start" id="wdStartBtn" title="Bắt đầu (F2)"><i class="fa-solid fa-table-cells-large"></i> Bắt đầu</button>
    <button class="wd-pin-nav" id="wdPinL" title="Cuộn trái" style="display:none"><i class="fa-solid fa-chevron-left"></i></button>
    <div class="wd-taskpins" id="wdTaskPins"></div>
    <button class="wd-pin-nav" id="wdPinR" title="Cuộn phải" style="display:none"><i class="fa-solid fa-chevron-right"></i></button>
    <div class="wd-tasks" id="wdTasks"></div>
    <div class="wd-tray">
        <div class="wd-tray-btn wd-bell-btn" id="wdBellBtn" title="Thông báo / nhắc việc"><i class="fa-solid fa-bell"></i><span class="wd-bell-badge" id="wdBellBadge" style="display:none">0</span></div>
        <div class="wd-tray-btn" id="wdWgBtn" title="Tiện ích (widget)"><i class="fa-solid fa-shapes"></i></div>
        <div class="wd-tray-btn" id="wdThemeBtn" title="Đổi giao diện Tối/Sáng"><i class="fa-solid fa-moon"></i></div>
        <div class="wd-tray-btn" id="wdWallBtn" title="Đổi ảnh nền"><i class="fa-solid fa-image"></i></div>
        <div class="wd-user">
            <i class="fa-solid fa-circle-user"></i><span>@hdUser</span>
            <div class="wd-user-menu">
                <a onclick="if(typeof DoiMatKhau==='function')DoiMatKhau()"><i class="fa-solid fa-key"></i> Đổi mật khẩu</a>
                <a onclick="chonThoiGianDangNhap()"><i class="fa-solid fa-clock"></i> Thời gian giữ đăng nhập</a>
                <a onclick="dangXuatSach()"><i class="fa-solid fa-arrow-right-from-bracket"></i> Đăng xuất</a>
            </div>
        </div>
        <span class="wd-clock" id="wdClock"></span>
    </div>
    <div class="wd-showdesk" id="wdShowDesk" title="Hiện màn hình nền (F4)"></div>
</div>

<div class="wd-wgpanel" id="wdWgPanel"></div>
<div class="wd-calflyout" id="wdCalFlyout"></div>
<div class="wd-notipanel" id="wdNotiPanel"></div>

<div class="wd-launcher" id="wdLauncher">
    <div class="wd-launcher-resize" id="wdLauncherResize" title="Kéo để đổi kích thước"></div>
    <div class="wd-launcher-search">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="wdAppSearch" placeholder="Tìm chức năng..." autocomplete="off" />
    </div>
    <div class="wd-launcher-main">
        <div class="wd-launcher-cats" id="wdLauncherCats" title="Trỏ chuột vào phân hệ để xem chức năng"></div>
        <div class="wd-launcher-apps" id="wdLauncherGrid"></div>
    </div>
    @* A1: dải phân hệ ĐÃ GHIM ở đáy start menu — bấm mở popup folder chức năng *@
    <div class="wd-launcher-pinned" id="wdLauncherPinned" style="display:none;flex-wrap:wrap;gap:6px;padding:7px 10px;border-top:1px solid rgba(120,140,160,.2);align-items:center"></div>
</div>

<div class="wd-wallpanel" id="wdWallPanel">
    <div class="wd-wp-title"><i class="fa-solid fa-image"></i> Ảnh nền</div>
    <div class="wd-walls" id="wdWalls"></div>
    <div class="wd-wp-custom">
        <button type="button" class="wd-wp-btn" id="wdPickWallBtn"><i class="fa-solid fa-image"></i> Thêm ảnh</button>
        <button type="button" class="wd-wp-btn" id="wdPickFolderBtn"><i class="fa-solid fa-folder-open"></i> Thêm cả thư mục</button>
        <input type="file" id="wdWallFile" accept="image/*" multiple style="display:none" />
        <input type="file" id="wdWallFolder" accept="image/*" multiple style="display:none" webkitdirectory directory />
        <div class="wd-wp-note" id="wdWallNote"></div>
    </div>
    <div class="wd-wp-subt" id="wdCustomTitle" style="display:none">Ảnh của bạn <span id="wdCustomCount"></span></div>
    <div class="wd-walls wd-customs" id="wdWallCustom"></div>
    <div class="wd-wp-row"><div class="wd-sw" id="wdSlideSw"></div><label>Tự đổi ảnh nền (slideshow)</label></div>
    <div class="wd-wp-row"><label>Chu kỳ:</label>
        <select id="wdSlideSec">
            <option value="15">15 giây</option><option value="30" selected>30 giây</option>
            <option value="60">1 phút</option><option value="300">5 phút</option><option value="900">15 phút</option>
        </select>
    </div>
</div>

<div class="wd-help-modal" id="wdHelpModal" onclick="if(event.target===this)this.classList.remove('open')">
    <div class="wd-help-box">
        <div class="wd-help-h"><i class="fa-solid fa-circle-question"></i> <span id="wdHelpTitle">Hướng dẫn</span>
            <span class="x" onclick="document.getElementById('wdHelpModal').classList.remove('open')"><i class="fa-solid fa-xmark"></i></span>
        </div>
        <div class="wd-help-b" id="wdHelpBody"></div>
    </div>
</div>

<div class="wd-ctxmenu" id="wdCtxMenu"></div>
<div class="wd-iconpick" id="wdIconPick"></div>

<script>
function wdBoot() {
    // ===== MeetSite — chỉ một phân hệ: Quản lý Hội nghị (ITKA). Mọi màn hình con điều hướng nội bộ trong app. =====
    var MODULES = [
        { route: 'HoiNghi', title: 'Quản lý Hội nghị', desc: 'Hội nghị · Đại biểu · Sơ đồ chỗ ngồi · Điểm danh · Tài liệu · Khảo sát · Báo cáo', icon: 'fa-users-rectangle', accent: '#0a6c5e', cat: 'Hội nghị' }
    ];
    // Thứ tự danh mục hiển thị trong Start menu
    var CATEGORIES = ['Tất cả', 'Hội nghị'];
    var CAT_ICON = { 'Tất cả': 'fa-table-cells-large', 'Hội nghị': 'fa-users-rectangle' };
    var USER = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(hdUser ?? "user"));
    var IS_ADMIN = @(hdIsAdmin ? "true" : "false"); // session Admin=true -> hiện widget "Người đang online"
    var WALLS = [
        'radial-gradient(120% 120% at 15% 10%, #16435a 0%, #0d2f43 45%, #0a2436 100%)',
        'linear-gradient(135deg,#0f2027,#203a43,#2c5364)',
        'linear-gradient(135deg,#1a2a6c,#2a5298)',
        'linear-gradient(135deg,#134e5e,#71b280)',
        'linear-gradient(135deg,#42275a,#734b6d)',
        'radial-gradient(120% 120% at 80% 10%,#3a1c4f,#1b1033 60%,#0a0a1a)',
        'linear-gradient(135deg,#2c3e50,#4ca1af)',
        'linear-gradient(135deg,#0b486b,#f56217)',
        'linear-gradient(135deg,#1f4037,#99f2c8)'
    ];
    // Mục PHÂN QUYỀN — chỉ thêm khi người dùng là Admin (gắn vào sau khi biết quyền, xem applyPermissions()).
    var PHANQUYEN_MOD = { route: 'PhanQuyen', title: 'Phân quyền', desc: 'Cấp quyền truy cập theo người dùng / nhóm', icon: 'fa-user-shield', accent: '#b0445b', cat: 'Hệ thống', adminOnly: true };
    var modByRoute = {}; MODULES.forEach(function (m) { modByRoute[m.route] = m; });
    // ============================================================
    // PHÂN QUYỀN MENU (Task 4): gọi /api/Auth/MyPermissions -> {code,isAdmin,allowed:[GroupKey...]}.
    // code==0 & isAdmin==false -> CHỈ hiện module có route(GroupKey) nằm trong allowed.
    // isAdmin==true -> hiện tất cả + thêm mục "Phân quyền".
    // Endpoint thiếu / lỗi / code!=0 -> FAIL-OPEN: hiện TẤT CẢ (không bao giờ khoá người dùng).
    // ============================================================
    var PERM = { loaded: false, isAdmin: IS_ADMIN, restrict: false, allowed: {} };
    function moduleVisible(route) {
        // Mục adminOnly chỉ hiện cho Admin.
        var m = modByRoute[route];
        if (m && m.adminOnly) return !!PERM.isAdmin;
        if (!PERM.restrict) return true;            // fail-open hoặc admin: hiện tất cả
        return !!PERM.allowed[route];               // chỉ module được cấp quyền
    }
    // Các module hiển thị (đã lọc quyền) — dùng chung cho Start menu, tìm kiếm, desktop, taskbar.
    function visibleModules() { return MODULES.filter(function (m) { return moduleVisible(m.route); }); }
    function applyPermissions(res) {
        if (res !== undefined) window.__lastPerm = res; // nhớ kết quả quyền để áp lại sau khi nạp menu động
        // res có thể null (lỗi/thiếu endpoint) -> fail-open.
        if (res && res.code === 0) {
            PERM.isAdmin = !!res.isAdmin;
            if (!res.isAdmin) {
                PERM.restrict = true; PERM.allowed = {};
                (res.allowed || []).forEach(function (k) { if (k != null) PERM.allowed['' + k] = true; });
            } else { PERM.restrict = false; }
        } else {
            // FAIL-OPEN: giữ nguyên (hiện tất cả). isAdmin theo session ban đầu.
            PERM.restrict = false;
        }
        PERM.loaded = true;
        // Admin: thêm "Phân quyền" + "Cấu hình dung lượng" vào nhóm Quản trị (chỉ 1 lần). Không còn module Phân quyền đứng riêng.
        if (PERM.isAdmin && FUNCS.QuanTri && !FUNCS.QuanTri.__adm) {
            // Chỉ thêm mục admin nếu route đó CHƯA tồn tại ở BẤT KỲ module nào (tránh nhân đôi khi user đã chuyển nó sang module khác).
            function menuHasRoute(route) {
                function scan(arr) { return Array.isArray(arr) && arr.some(function (n) { return n.r === route || scan(n.children); }); }
                return Object.keys(FUNCS).some(function (k) { return scan(FUNCS[k]); });
            }
            function addAdm(it) { if (!menuHasRoute(it.r)) FUNCS.QuanTri.push(it); }
            addAdm({ t: 'Phân quyền người dùng', i: 'fa-user-shield', r: 'PhanQuyen' });
            addAdm({ t: 'Cấu hình dung lượng Office', i: 'fa-database', r: 'VanPhong/QuotaConfig' });
            addAdm({ t: 'Cấu hình menu (Start)', i: 'fa-bars-staggered', r: '__menucfg__' });
            addAdm({ t: 'Sao lưu dữ liệu', i: 'fa-download', r: 'Backup' });
            addAdm({ t: 'Cập nhật phần mềm', i: 'fa-cloud-arrow-down', r: 'CapNhat' });
            FUNCS.QuanTri.__adm = true;
        }
        IS_ADMIN = PERM.isAdmin; // đồng bộ cờ admin (widget online...) theo kết quả server
        // Nếu module đang chọn trong Start bị ẩn -> chuyển về module hợp lệ đầu tiên.
        if (curModule !== '__fav__' && !moduleVisible(curModule)) { var vm = visibleModules(); curModule = vm.length ? vm[0].route : MODULES[0].route; lsSet('startModule', curModule); }
        try { renderCats(); renderApps(); renderIcons(); renderTaskPins(); renderWidgets(); } catch (e) { }
    }
    function loadPermissions() {
        return fetch('/api/Auth/MyPermissions', { credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
            .then(function (r) { return r.ok ? r.json() : null; })
            .then(function (res) { applyPermissions(res); })
            .catch(function () { applyPermissions(null); }); // FAIL-OPEN
    }
    // ====== MENU ĐỘNG (cấu hình từ DB, fallback hardcoded) ======
    // Áp config: thay MODULES/FUNCS TẠI CHỖ (giữ tham chiếu) rồi áp lại quyền + render.
    var _menuDefCaptured = false, MODULES_DEFAULT = [], FUNCS_DEFAULT = {};
    function applyMenuConfig(cfg) {
        if (!cfg || !Array.isArray(cfg.modules) || !cfg.modules.length) return false;
        // Chụp lại danh sách MẶC ĐỊNH (hardcoded) lần đầu — để bổ sung module MỚI chưa có trong cấu hình đã lưu.
        if (!_menuDefCaptured) { _menuDefCaptured = true; MODULES_DEFAULT = MODULES.slice(); try { FUNCS_DEFAULT = JSON.parse(JSON.stringify(FUNCS)); } catch (e) { FUNCS_DEFAULT = {}; } }
        MODULES.length = 0; cfg.modules.forEach(function (m) { MODULES.push(m); });
        // Tự THÊM module mặc định nào CHƯA có trong cấu hình đã lưu (vd phân hệ mới deploy sau khi lưu menu).
        MODULES_DEFAULT.forEach(function (m) { if (!MODULES.some(function (x) { return x.route === m.route; })) MODULES.push(m); });
        // Đưa 'Chức năng' (Quản trị) + cấu hình xuống CUỐI cùng.
        var _qi = MODULES.findIndex(function (m) { return m.route === 'QuanTri'; });
        if (_qi >= 0) MODULES.push(MODULES.splice(_qi, 1)[0]);
        Object.keys(modByRoute).forEach(function (k) { delete modByRoute[k]; });
        MODULES.forEach(function (m) { modByRoute[m.route] = m; });
        if (cfg.funcs && typeof cfg.funcs === 'object') {
            Object.keys(FUNCS).forEach(function (k) { delete FUNCS[k]; });
            Object.keys(cfg.funcs).forEach(function (k) { FUNCS[k] = cfg.funcs[k]; });
            // Bổ sung submenu mặc định của các module mới (key chưa có trong cấu hình đã lưu).
            Object.keys(FUNCS_DEFAULT).forEach(function (k) { if (!FUNCS[k]) FUNCS[k] = FUNCS_DEFAULT[k]; });
        }
        applyPermissions(window.__lastPerm); // thêm lại mục admin (có dedupe) + render lại
        return true;
    }
    function loadMenuConfig() {
        return fetch('/api/Menu/GetStartMenu', { credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
            .then(function (r) { return r.ok ? r.json() : null; })
            .then(function (res) {
                if (res && res.code === 0 && res.data && res.data.NoiDung) {
                    try { applyMenuConfig(JSON.parse(res.data.NoiDung)); }
                    catch (e) { if (window.console) console.warn('Cấu hình menu JSON lỗi, dùng mặc định:', e); }
                }
            }).catch(function () { });
    }
    // Cửa sổ cấu hình menu (admin) — sửa JSON modules/funcs.
    function openMenuConfig() {
        if (!document.getElementById('wdMcStyle')) {
            var st = document.createElement('style'); st.id = 'wdMcStyle';
            st.textContent = '.wd-mc-ovl{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200000;display:flex;align-items:center;justify-content:center;}'
                + '.wd-mc-box{width:980px;max-width:96vw;height:84vh;background:#fff;color:#1f2937;border-radius:10px;display:flex;flex-direction:column;box-shadow:0 18px 60px rgba(0,0,0,.5);overflow:hidden;}'
                + '.wd-mc-h{padding:12px 16px;font-weight:700;background:#2b579a;color:#fff;display:flex;justify-content:space-between;align-items:center;}'
                + '.wd-mc-x{cursor:pointer;font-size:20px;}'
                + '.wd-mc-hbtns{display:flex;align-items:center;gap:14px;}.wd-mc-mx{cursor:pointer;font-size:16px;}'
                + '.wd-mc-box.max{width:100vw;height:100vh;max-width:none;border-radius:0;}'
                + '.wd-mc-body{flex:1;display:flex;min-height:0;}'
                + '.wd-mc-col{display:flex;flex-direction:column;min-height:0;}'
                + '.wd-mc-left{flex:0 0 320px;border-right:1px solid #e5e7eb;}.wd-mc-right{flex:1;min-width:0;}'
                + '.wd-mc-ct{padding:8px 12px;font-weight:700;font-size:12px;text-transform:uppercase;color:#6b7280;display:flex;justify-content:space-between;align-items:center;}'
                + '.wd-mc-scroll{flex:1;overflow:auto;padding:8px 10px 12px;background:#f7f9fc;}'
                + '.wd-mc-row{border:1px solid #e5e7eb;border-left:4px solid #cbd5e1;border-radius:8px;padding:9px 10px;margin-bottom:8px;background:#fff;}'
                + '.wd-mc-row.sel{border-left-color:#2b579a;box-shadow:0 2px 10px rgba(43,87,154,.15);}'
                + '.wd-mc-mhead{display:flex;align-items:center;gap:9px;margin-bottom:6px;}'
                + '.wd-mc-mico{width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:13px;flex:0 0 auto;}'
                + '.wd-mc-mtitle{flex:1;min-width:0;border:1px solid #dbe1e8;border-radius:6px;font-weight:700;font-size:13.5px;padding:5px 9px;background:#fff;color:#1f2937;}'
                + '.wd-mc-mtitle:focus{outline:none;border-color:#2b579a;box-shadow:0 0 0 2px rgba(43,87,154,.12);}'
                + '.wd-mc-sw{width:26px;height:26px;border-radius:6px;border:1px solid #d1d5db;cursor:pointer;padding:0;flex:0 0 auto;}'
                + '.wd-mc-fld{display:flex;align-items:center;gap:6px;margin:4px 0;}'
                + '.wd-mc-fld label{width:46px;font-size:11px;color:#9ca3af;flex:0 0 auto;}'
                + '.wd-mc-in{flex:1;min-width:0;border:1px solid #dbe1e8;border-radius:6px;padding:5px 8px;font-size:12.5px;}'
                + '.wd-mc-in:focus{outline:none;border-color:#2b579a;}'
                + '.wd-mc-ipv{width:22px;text-align:center;color:#2b579a;flex:0 0 auto;font-size:13px;}'
                + '.wd-mc-node{margin:5px 0;}'
                + '.wd-mc-node .wd-mc-nrow{display:flex;align-items:center;gap:5px;padding:4px 6px;border-radius:7px;}'
                + '.wd-mc-node.grp>.wd-mc-nrow{background:#eaf1fb;border:1px solid #cfe0f7;}'
                + '.wd-mc-node.grp>.wd-mc-nrow .n-title{font-weight:700;color:#1d4ed8;}'
                + '.wd-mc-node.grp>.wd-mc-nrow .wd-mc-ipv{color:#1d4ed8;}'
                + '.wd-mc-mini{border:1px solid #d8dee6;background:#fff;color:#64748b;border-radius:5px;cursor:pointer;font-size:11px;padding:4px 7px;line-height:1;flex:0 0 auto;}'
                + '.wd-mc-mini.del:hover{background:#fef2f2;color:#b91c1c;border-color:#f0b4b4;}.wd-mc-mini:hover{background:#eef2ff;color:#2b579a;}'
                + '.wd-mc-children{margin-left:14px;border-left:2px solid #dbe7fb;padding-left:10px;margin-top:2px;}'
                + '.wd-mc-add{border:1px dashed #93b4e6;background:#fff;color:#2563eb;border-radius:7px;cursor:pointer;font-size:12px;padding:6px 12px;margin:5px 0;font-weight:600;}'
                + '.wd-mc-add:hover{background:#eff5ff;}'
                + '.wd-mc-foot{display:flex;gap:8px;align-items:center;padding:12px 16px;border-top:1px solid #e5e7eb;}'
                + '.wd-mc-btn{padding:8px 16px;border:1px solid #d1d5db;background:#fff;color:#374151;border-radius:7px;cursor:pointer;font-size:13px;}'
                + '.wd-mc-btn.primary{background:#2b579a;color:#fff;border-color:#2b579a;}';
            document.head.appendChild(st);
        }
        // Bản sao làm việc (không đụng MODULES/FUNCS thật cho tới khi Lưu)
        var cfg = JSON.parse(JSON.stringify({ modules: MODULES, funcs: FUNCS }));
        if (!Array.isArray(cfg.modules)) cfg.modules = [];
        if (!cfg.funcs || typeof cfg.funcs !== 'object') cfg.funcs = {};
        var sel = cfg.modules.length ? cfg.modules[0].route : null;

        var ov = document.createElement('div'); ov.className = 'wd-mc-ovl';
        ov.innerHTML = '<div class="wd-mc-box"><div class="wd-mc-h"><span>Cấu hình Start menu</span><span class="wd-mc-hbtns"><span class="wd-mc-mx" title="Phóng to / thu nhỏ">⛶</span><span class="wd-mc-x" title="Đóng">×</span></span></div>'
            + '<div class="wd-mc-body">'
            + '<div class="wd-mc-col wd-mc-left"><div class="wd-mc-ct"><span>Module</span><button class="wd-mc-mini" id="mcAddMod">+ Thêm module</button></div><div class="wd-mc-scroll" id="mcMods"></div></div>'
            + '<div class="wd-mc-col wd-mc-right"><div class="wd-mc-ct" id="mcFnTitle">Chức năng</div><div class="wd-mc-scroll" id="mcFns"></div></div>'
            + '</div>'
            + '<div class="wd-mc-foot"><button class="wd-mc-btn" data-a="reset">Khôi phục mặc định</button><span style="flex:1"></span><button class="wd-mc-btn" data-a="close">Đóng</button><button class="wd-mc-btn primary" data-a="save">Lưu</button></div></div>';
        document.body.appendChild(ov);
        function $q(s) { return ov.querySelector(s); }
        function esc2(s) { return String(s == null ? '' : s).replace(/"/g, '&quot;').replace(/</g, '&lt;'); }
        function inp(ph, val, cls) { return '<input class="wd-mc-in ' + (cls || '') + '" placeholder="' + ph + '" value="' + esc2(val) + '"/>'; }

        function renderMods() {
            var h = '';
            cfg.modules.forEach(function (m, i) {
                var ac = m.accent || '#0a6c5e';
                h += '<div class="wd-mc-row' + (m.route === sel ? ' sel' : '') + '" data-i="' + i + '">'
                    + '<div class="wd-mc-mhead">'
                    + '<span class="wd-mc-mico" style="background:' + esc2(ac) + '"><i class="fa-solid ' + esc2(m.icon || 'fa-window-maximize') + '"></i></span>'
                    + '<input class="wd-mc-mtitle f-title" value="' + esc2(m.title) + '" placeholder="Tên module"/>'
                    + '<input type="color" class="wd-mc-sw f-accent" value="' + esc2(/^#[0-9a-fA-F]{6}$/.test(ac) ? ac : '#0a6c5e') + '" title="Màu"/>'
