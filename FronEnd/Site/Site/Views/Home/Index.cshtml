    // Rải MỌI NHÓM trong danh mục DmReportGroup (KỂ CẢ nhóm chưa có báo cáo) thành 1 chức năng
    // -> mở /Report/key/<key> để vào đó thêm/cấu hình báo cáo cho nhóm. Kèm 2 mục quản lý.
    // Dùng GetAllGroups (tự seed 5 phân hệ chuẩn nếu danh mục rỗng), không phải GetGroups (chỉ nhóm có báo cáo).
    function loadReportGroups() {
        try {
            fetch('/api/Report/GetAllGroups', {
                method: 'POST', credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' }, body: '{}'
            }).then(function (r) { return r.ok ? r.json() : null; }).then(function (res) {
                var leaves = [];
                if (res && res.code === 0 && res.data && res.data.length) {
                    leaves = res.data.map(function (g) {
                        var key = (g.GroupKey == null ? '' : ('' + g.GroupKey));
                        var name = (g.GroupName == null || g.GroupName === '') ? key : ('' + g.GroupName);
                        var icon = (g.Icon == null || ('' + g.Icon).trim() === '') ? 'fa-chart-line' : ('' + g.Icon).trim();
                        return { t: name, i: icon, r: 'Report/key/' + key };
                    });
                }
                // Kèm mục cấu hình nhóm ở cuối (đã bỏ "Quản lý báo cáo" theo yêu cầu).
                leaves.push({ t: '⚙ Cấu hình nhóm báo cáo', i: 'fa-layer-group', r: 'ReportGroupConfig' });
                FUNCS.Report = leaves;
                refreshStartIcons();
            }).catch(function () { });
        } catch (e) { }
    }
    function funcsOf(route) {
        var m = modByRoute[route];
        return FUNCS[route] || [{ t: 'Mở ' + (m ? m.title : route), i: (m ? m.icon : 'fa-window-maximize'), r: route }];
    }
    function accOf(route) { var m = modByRoute[route]; return (m && m.accent) || '#0a6c5e'; }
    var favs = lsGet('startFavs', []); // [{r,t,i,acc}]
    function isFav(r, t) { return favs.some(function (f) { return f.r === r && f.t === t; }); }
    function toggleFav(r, t, i, acc) {
        if (isFav(r, t)) favs = favs.filter(function (f) { return !(f.r === r && f.t === t); });
        else favs.push({ r: r, t: t, i: i, acc: acc });
        lsSet('startFavs', favs);
    }
    var curModule = lsGet('startModule', MODULES[0].route);
    if (curModule !== '__fav__' && !modByRoute[curModule]) curModule = MODULES[0].route;
    function renderCats() {
        var html = '';
        if (favs.length) html += '<div class="wd-cat fav' + (curModule === '__fav__' ? ' on' : '') + '" data-route="__fav__"><i class="fa-solid fa-star"></i><span>Yêu thích</span></div><div class="wd-cat-sep"></div>';
        // GiaoViec/CRM/QAQC/Website gộp vào "Chức năng khác" (QuanTri) -> ẩn khỏi danh sách tab riêng.
        var OTHERSET = { GiaoViec: 1, CRM: 1, QAQC: 1, Website: 1 };
        html += visibleModules().filter(function (m) { return !OTHERSET[m.route]; }).map(function (m) {
            return '<div class="wd-cat' + (m.route === curModule ? ' on' : '') + '" data-route="' + m.route + '" style="--accent:' + m.accent + '"><i class="fa-solid ' + effIcon(m.route, m.icon) + '"></i><span>' + esc(m.title) + '</span></div>';
        }).join('');
        var host = document.getElementById('wdLauncherCats');
        host.innerHTML = html;
        Array.prototype.forEach.call(host.querySelectorAll('.wd-cat'), function (el) {
            var r = el.getAttribute('data-route');
            function sel() { curModule = r; lsSet('startModule', r); document.getElementById('wdAppSearch').value = ''; renderCats(); renderApps(); }
            el.addEventListener('mouseenter', sel);
            el.addEventListener('click', sel);
            el.addEventListener('contextmenu', function (e) {
                if (r === '__fav__' || r === '__other__') return;
                e.preventDefault();
                var m = modByRoute[r] || { title: el.textContent.trim(), icon: 'fa-window-maximize', accent: '#0a6c5e' };
                openCtxMenu(e.clientX, e.clientY, r, 'launcher', m);
            });
        });
    }
    // Dòng chức năng: icon -> text, 1 dòng. r = route mở đúng view.
    function leafHtml(r, t, i, acc) {
        var ic = effIcon(r, i || 'fa-window-maximize'); // dùng icon đã đổi nếu route trùng app đã override
        return '<div class="wd-fn" data-r="' + esc(r) + '" data-t="' + esc(t) + '" data-i="' + (i || '') + '" data-acc="' + acc + '">'
            + '<i class="wd-fn-ico fa-solid ' + ic + '" style="color:' + acc + '"></i>'
            + '<span class="wd-fn-t">' + esc(t) + '</span>'
            + '<i class="wd-fav-star fa-' + (isFav(r, t) ? 'solid' : 'regular') + ' fa-star" title="Ghim vào Yêu thích"></i></div>';
    }
    function renderApps() {
        var q = (document.getElementById('wdAppSearch').value || '').trim().toLowerCase();
        var host = document.getElementById('wdLauncherGrid');
        var html = '';
        if (q) {
            visibleModules().forEach(function (m) {
                var acc = m.accent;
                funcsOf(m.route).forEach(function (it) {
                    (it.children || [it]).forEach(function (c) {
                        if ((c.t + ' ' + m.title).toLowerCase().indexOf(q) >= 0) html += leafHtml(c.r, c.t, c.i, acc);
                    });
                });
            });
        } else if (curModule === '__fav__') {
            favs.forEach(function (f) { html += leafHtml(f.r, f.t, f.i, f.acc || '#0a6c5e'); });
        } else {
            var acc = accOf(curModule);
            funcsOf(curModule).forEach(function (it) {
                if (it.children) {
                    html += '<div class="wd-fgroup"><i class="fa-solid ' + (it.i || 'fa-folder') + '"></i> ' + esc(it.t) + '</div>';
                    it.children.forEach(function (c) { html += leafHtml(c.r, c.t, c.i, acc); });
                } else {
                    html += leafHtml(it.r, it.t, it.i, acc);
                }
            });
            // "Chức năng khác" (QuanTri) gộp thêm Giao việc / CRM / QA-QC / Thiết kế web
            if (curModule === 'QuanTri') {
                ['GiaoViec', 'CRM', 'QAQC', 'Website'].forEach(function (rt) {
                    var m = modByRoute[rt]; if (!m || (typeof moduleVisible === 'function' && !moduleVisible(rt))) return;
                    html += '<div class="wd-fgroup"><i class="fa-solid ' + (m.icon || 'fa-folder') + '"></i> ' + esc(m.title) + '</div>';
                    funcsOf(rt).forEach(function (it) {
                        if (it.children) { it.children.forEach(function (c) { html += leafHtml(c.r, c.t, c.i, m.accent); }); }
                        else { html += leafHtml(it.r, it.t, it.i, m.accent); }
