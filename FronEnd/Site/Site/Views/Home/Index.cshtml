            bindWgDrag(el, el.querySelector('.wd-wg-head'), d.id);
            bindWgResize(el, grip, d.id);
            if (d.id === 'notes') { var ta = el.querySelector('textarea'); if (ta) ta.addEventListener('input', function () { widgets.notes = ta.value; saveWidgets(); }); }
            if (d.id === 'quick') Array.prototype.forEach.call(el.querySelectorAll('.wd-wg-q'), function (q) { q.addEventListener('click', function () { var r = q.getAttribute('data-r'); window.wdOpenApp(r, metaOf(r)); }); });
            if (d.id === 'api') wgLoadApi(el);
            if (d.id === 'online') wgLoadOnline(el);
            if (d.id === 'lichvn') { var body = el.querySelector('.wd-wg-body'); if (body) { body.style.cursor = 'pointer'; body.addEventListener('click', function (e) { e.stopPropagation(); window.wdOpenCalendar(); }); } }
            if (d.id === 'lichnhac') { if (!NOTI.loaded) loadNoti().then(function () { var b2 = el.querySelector('.wd-wg-body'); if (b2) b2.innerHTML = wgLichNhacHtml(); }); }
        });
        updateWgDynamic();
    }
    // Tự xếp lại các widget đang bật theo cột bên phải màn hình.
    function arrangeWidgets() {
        var i = 0;
        wgAvail().forEach(function (d) {
            if (!widgets.on[d.id]) return;
            widgets.pos[d.id] = defWgPos(d.id, i); i++;
        });
        saveWidgets(); renderWidgets();
    }
    // Khôi phục mặc định: tắt hết vị trí/kích thước tùy biến.
    function resetWidgets() {
        widgets.pos = {}; widgets.size = {};
        saveWidgets(); renderWidgets();
    }
    var wgDesignOn = false; // chế độ thiết kế: hiện viền kéo-thả rõ ràng
    function setWgDesign(on) { wgDesignOn = !!on; if (wgHost) wgHost.classList.toggle('wd-designing', wgDesignOn); renderWidgets(); }
    // ---- "Thiết kế widget": catalog thêm/bớt + sắp xếp + chế độ thiết kế. Lưu theo tài khoản. ----
    function renderWgPanel() {
        var pnl = document.getElementById('wdWgPanel'); if (!pnl) return;
        var avail = wgAvail();
        var onCount = avail.filter(function (d) { return widgets.on[d.id]; }).length;
        var html = '<div class="h"><i class="fa-solid fa-shapes"></i> Thiết kế widget</div>';
        html += '<div class="wd-wg-sub">Đang hiển thị <b>' + onCount + '</b>/' + avail.length + ' tiện ích. Chọn tiện ích trong danh sách để <b>thêm/bớt</b>, bật <b>Chế độ thiết kế</b> rồi <b>kéo</b> để sắp xếp, kéo góc dưới-phải để đổi kích thước. Cấu hình lưu <b>theo tài khoản</b> (đồng bộ mọi máy).</div>';
        html += '<div class="wd-wg-design-row"><span class="nm"><i class="fa-solid fa-pen-ruler"></i> Chế độ thiết kế</span><span class="wd-sw' + (wgDesignOn ? ' on' : '') + '" data-design="1"></span></div>';
        html += '<div class="wd-wg-catt">Bộ tiện ích</div>';
        html += '<div class="wd-wg-catalog">' + avail.map(function (d) {
            var on = !!widgets.on[d.id];
            return '<div class="wd-wg-card' + (on ? ' on' : '') + '" data-id="' + d.id + '">'
                + '<i class="ci fa-solid ' + d.i + '"></i>'
                + '<div class="ct"><b>' + esc(d.t) + '</b><small>' + esc(d.desc || '') + '</small></div>'
                + '<span class="wd-wg-add' + (on ? ' on' : '') + '" title="' + (on ? 'Bỏ khỏi màn hình' : 'Thêm vào màn hình') + '"><i class="fa-solid ' + (on ? 'fa-check' : 'fa-plus') + '"></i></span>'
                + '</div>';
        }).join('') + '</div>';
        html += '<div class="wd-wg-acts">'
            + '<button type="button" class="wd-wg-act" data-act="arrange"><i class="fa-solid fa-table-cells"></i> Sắp xếp gọn</button>'
            + '<button type="button" class="wd-wg-act" data-act="reset"><i class="fa-solid fa-rotate-left"></i> Đặt lại vị trí</button>'
            + '<button type="button" class="wd-wg-act" data-act="wall"><i class="fa-solid fa-image"></i> Đổi ảnh nền</button>'
            + '</div>';
        pnl.innerHTML = html;
        Array.prototype.forEach.call(pnl.querySelectorAll('.wd-wg-card'), function (row) {
            row.addEventListener('click', function (e) { e.stopPropagation(); var id = row.getAttribute('data-id'); widgets.on[id] = !widgets.on[id]; saveWidgets(); renderWidgets(); renderWgPanel(); });
        });
        var dsw = pnl.querySelector('.wd-sw[data-design]');
        if (dsw) dsw.addEventListener('click', function (e) { e.stopPropagation(); setWgDesign(!wgDesignOn); renderWgPanel(); });
        Array.prototype.forEach.call(pnl.querySelectorAll('.wd-wg-act'), function (b) {
            b.addEventListener('click', function (e) {
                e.stopPropagation(); var a = b.getAttribute('data-act');
                if (a === 'arrange') arrangeWidgets();
                else if (a === 'reset') resetWidgets();
                else if (a === 'wall') { pnl.classList.remove('open'); document.getElementById('wdWallPanel').classList.add('open'); }
                renderWgPanel();
            });
        });
    }
    document.getElementById('wdWgBtn').addEventListener('click', function (e) { e.stopPropagation(); var pnl = document.getElementById('wdWgPanel'); renderWgPanel(); pnl.classList.toggle('open'); document.getElementById('wdLauncher').classList.remove('open'); document.getElementById('wdWallPanel').classList.remove('open'); });

    // ============================================================
    // THÔNG BÁO / NHẮC VIỆC — chuông góc dưới-phải + panel trượt + toast.
    // Nguồn dữ liệu: GET /api/Notify/All -> {code,count,overdueCount,data:[{type,title,detail,due,overdue,route}]}.
    // Dùng CHUNG cho: badge chuông, panel thông báo, và widget "Lịch nhắc".
    // "Đã đọc" lưu cục bộ theo USER (key = type|title|due) -> đánh dấu đã đọc không gọi server.
    // ============================================================
    var NOTI = { list: [], loaded: false, loading: false };
    function notiKey(n) { return (n.type || '') + '|' + (n.title || '') + '|' + (n.detail || '') + '|' + (n.due || ''); }
    var notiRead = lsGet('notiRead.' + USER, {}); // {key:true} các thông báo đã đánh dấu đọc
    function isNotiRead(n) { return !!notiRead[notiKey(n)]; }
    function markAllNotiRead() { (NOTI.list || []).forEach(function (n) { notiRead[notiKey(n)] = true; }); lsSet('notiRead.' + USER, notiRead); refreshNotiBadge(); if (document.getElementById('wdNotiPanel').classList.contains('open')) renderNotiPanel(); }
    // Số thông báo "chưa đọc" — badge ưu tiên đếm quá hạn nhưng gộp cả chưa đọc.
    function notiUnreadCount() { return (NOTI.list || []).filter(function (n) { return !isNotiRead(n); }).length; }
    function notiOverdueUnread() { return (NOTI.list || []).filter(function (n) { return n.overdue && !isNotiRead(n); }).length; }
    function refreshNotiBadge() {
        var badge = document.getElementById('wdBellBadge'); if (!badge) return;
        var od = notiOverdueUnread(), un = notiUnreadCount();
        var n = un; // hiện TỔNG số chưa đọc; tô đỏ (overdue) nếu có việc quá hạn
        badge.textContent = n > 99 ? '99+' : ('' + n);
        badge.style.display = n > 0 ? '' : 'none';
        badge.classList.toggle('overdue', od > 0);
        var btn = document.getElementById('wdBellBtn'); if (btn) btn.classList.toggle('has-overdue', od > 0);
    }
    function loadNoti() {
        if (NOTI.loading) return Promise.resolve(NOTI.list);
        NOTI.loading = true;
        return fetch('/api/Notify/All', { credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
            .then(function (r) { return r.ok ? r.json() : null; })
            .then(function (d) {
                NOTI.list = (d && d.code === 0 && d.data) ? d.data : [];
                NOTI.loaded = true; NOTI.loading = false;
                refreshNotiBadge();
                // Làm mới widget Lịch nhắc nếu đang bật.
                var lrEl = wgHost && wgHost.querySelector('.wd-wg-lichnhac .wd-wg-body'); if (lrEl) lrEl.innerHTML = wgLichNhacHtml();
                return NOTI.list;
            })
            .catch(function () { NOTI.loaded = true; NOTI.loading = false; return NOTI.list; });
    }
    // Gom thông báo theo "type" để render thành nhóm.
    function notiGroups() {
        var g = {}, order = [];
        (NOTI.list || []).forEach(function (n) { var t = n.type || 'Khác'; if (!g[t]) { g[t] = []; order.push(t); } g[t].push(n); });
        return order.map(function (t) { return { type: t, items: g[t] }; });
    }
    function fmtDue(due) {
        if (!due) return '';
        var d = new Date(due); if (isNaN(d.getTime())) return '';
        var p = function (n) { return (n < 10 ? '0' : '') + n; };
        return p(d.getDate()) + '/' + p(d.getMonth() + 1) + '/' + d.getFullYear();
    }
    function renderNotiPanel() {
        var pnl = document.getElementById('wdNotiPanel'); if (!pnl) return;
        var groups = notiGroups();
        var total = (NOTI.list || []).length, od = (NOTI.list || []).filter(function (n) { return n.overdue; }).length;
        var html = '<div class="wd-noti-h"><span class="ti"><i class="fa-solid fa-bell"></i> Thông báo</span>'
            + '<span class="wd-noti-actions">'
            + '<button type="button" class="wd-noti-clear" id="wdNotiClear" title="Đánh dấu tất cả đã đọc"><i class="fa-solid fa-check-double"></i> Đánh dấu đã đọc</button>'
            + '<span class="wd-noti-x" id="wdNotiX" title="Đóng"><i class="fa-solid fa-xmark"></i></span>'
            + '</span></div>';
        html += '<div class="wd-noti-sub">' + (total ? (total + ' thông báo' + (od ? ' · <b class="od">' + od + ' quá hạn</b>' : '')) : 'Không có thông báo nào.') + '</div>';
        html += '<div class="wd-noti-list">';
        if (!total) {
            html += '<div class="wd-noti-empty"><i class="fa-regular fa-bell-slash"></i><span>Bạn đã xử lý hết. Tuyệt vời!</span></div>';
        } else {
            groups.forEach(function (gr) {
                html += '<div class="wd-noti-grp"><div class="wd-noti-grp-t">' + esc(gr.type) + ' <span>(' + gr.items.length + ')</span></div>';
                gr.items.forEach(function (n, i) {
                    var read = isNotiRead(n);
                    html += '<div class="wd-noti-item' + (n.overdue ? ' overdue' : '') + (read ? ' read' : '') + '" data-type="' + esc(gr.type) + '" data-i="' + i + '"' + (n.route ? ' data-route="' + esc(n.route) + '"' : '') + '>'
                        + '<div class="wd-noti-dot"></div>'
                        + '<div class="wd-noti-body"><div class="wd-noti-title">' + esc(n.title) + '</div>'
                        + '<div class="wd-noti-detail">' + esc(n.detail) + '</div>'
                        + '<div class="wd-noti-meta">' + (n.due ? '<span class="wd-noti-due' + (n.overdue ? ' od' : '') + '"><i class="fa-regular fa-clock"></i> ' + esc(fmtDue(n.due)) + '</span>' : '')
                        + (n.overdue ? '<span class="wd-noti-tag">Quá hạn</span>' : '') + '</div></div>'
                        + '<button type="button" class="wd-noti-toggle" data-toggle="1" title="' + (read ? 'Đánh dấu chưa đọc' : 'Đánh dấu đã đọc') + '"><i class="fa-solid ' + (read ? 'fa-rotate-left' : 'fa-check') + '"></i></button>'
                        + (n.route ? '<i class="wd-noti-open fa-solid fa-up-right-from-square" title="Mở"></i>' : '')
                        + '</div>';
                });
                html += '</div>';
            });
        }
        html += '</div>';
        pnl.innerHTML = html;
        var cx = pnl.querySelector('#wdNotiX'); if (cx) cx.addEventListener('click', function (e) { e.stopPropagation(); pnl.classList.remove('open'); });
        var cl = pnl.querySelector('#wdNotiClear'); if (cl) cl.addEventListener('click', function (e) { e.stopPropagation(); markAllNotiRead(); });
        Array.prototype.forEach.call(pnl.querySelectorAll('.wd-noti-toggle'), function (tg) {
            tg.addEventListener('click', function (e) {
                e.stopPropagation();
                var it = tg.closest('.wd-noti-item'); if (!it) return;
                var t = it.getAttribute('data-type'), i = +it.getAttribute('data-i');
                var grp = notiGroups().filter(function (g) { return g.type === t; })[0];
                var n = grp ? grp.items[i] : null; if (!n) return;
                var k = notiKey(n);
                if (notiRead[k]) delete notiRead[k]; else notiRead[k] = true; // toggle đã đọc / chưa đọc
                lsSet('notiRead.' + USER, notiRead);
                refreshNotiBadge(); renderNotiPanel();
            });
        });
        Array.prototype.forEach.call(pnl.querySelectorAll('.wd-noti-item'), function (it) {
            it.addEventListener('click', function (e) {
                if (e.target.closest('.wd-noti-toggle')) return; // bấm nút toggle thì bỏ qua điều hướng
                e.stopPropagation();
                var t = it.getAttribute('data-type'), i = +it.getAttribute('data-i');
                var grp = notiGroups().filter(function (g) { return g.type === t; })[0];
                var n = grp ? grp.items[i] : null;
                if (n) { notiRead[notiKey(n)] = true; lsSet('notiRead.' + USER, notiRead); }
                var route = it.getAttribute('data-route');
                if (route) { pnl.classList.remove('open'); window.wdOpenApp(route, metaOf(route.split('#')[0])); }
                refreshNotiBadge(); renderNotiPanel();
            });
        });
    }
    function toggleNotiPanel(force) {
        var pnl = document.getElementById('wdNotiPanel');
        var willOpen = (force === true) ? true : (force === false ? false : !pnl.classList.contains('open'));
        if (willOpen) {
            // Mở -> tải mới rồi render.
            loadNoti().then(renderNotiPanel);
            renderNotiPanel();
            pnl.classList.add('open');
            document.getElementById('wdLauncher').classList.remove('open');
            document.getElementById('wdWgPanel').classList.remove('open');
            document.getElementById('wdWallPanel').classList.remove('open');
            document.getElementById('wdCalFlyout').classList.remove('open');
        } else { pnl.classList.remove('open'); }
    }
    document.getElementById('wdBellBtn').addEventListener('click', function (e) { e.stopPropagation(); toggleNotiPanel(); });

    // ---- Toast (góc dưới-phải) — báo nhanh khi vào app nếu có việc quá hạn ----
    function wdToast(opt) {
        opt = opt || {};
        var host = document.getElementById('wdToastHost');
        if (!host) { host = document.createElement('div'); host.id = 'wdToastHost'; host.className = 'wd-toast-host'; document.body.appendChild(host); }
        var el = document.createElement('div'); el.className = 'wd-toast' + (opt.type ? ' ' + opt.type : '');
        el.innerHTML = '<i class="wd-toast-ic fa-solid ' + (opt.icon || 'fa-bell') + '"></i>'
            + '<div class="wd-toast-c"><div class="wd-toast-t">' + esc(opt.title || '') + '</div>'
            + (opt.detail ? '<div class="wd-toast-d">' + esc(opt.detail) + '</div>' : '') + '</div>'
            + '<i class="wd-toast-x fa-solid fa-xmark"></i>';
        host.appendChild(el);
        setTimeout(function () { el.classList.add('show'); }, 20);
        function kill() { el.classList.remove('show'); setTimeout(function () { if (el.parentNode) el.parentNode.removeChild(el); }, 280); }
        el.querySelector('.wd-toast-x').addEventListener('click', function (e) { e.stopPropagation(); kill(); });
        if (opt.onClick) el.addEventListener('click', function (e) { if (e.target.closest('.wd-toast-x')) return; opt.onClick(); kill(); });
        setTimeout(kill, opt.timeout || 8000);
        return el;
    }

    // ---- Widget "Lịch nhắc": gộp mọi loại nhắc việc (dùng chung nguồn với chuông) ----
    function wgLichNhacHtml() {
        var list = (NOTI.list || []);
        if (!NOTI.loaded) return '<div class="wd-ln-ld">Đang tải nhắc việc…</div>';
        if (!list.length) return '<div class="wd-ln-empty"><i class="fa-regular fa-circle-check"></i> Không có việc cần nhắc.</div>';
        var od = list.filter(function (n) { return n.overdue; }).length;
        var top = list.slice(0, 6);
        var h = '<div class="wd-ln-sum"><b>' + list.length + '</b> nhắc việc' + (od ? ' · <span class="od">' + od + ' quá hạn</span>' : '') + '</div>';
        h += top.map(function (n) {
            return '<div class="wd-ln-row' + (n.overdue ? ' od' : '') + '"' + (n.route ? ' data-route="' + esc(n.route) + '"' : '') + ' onclick="wdLnGo(this.getAttribute(\'data-route\'))" style="cursor:pointer" title="' + (n.route ? 'Mở cửa sổ liên quan' : '') + '"><span class="d"></span>'
                + '<div class="c"><b>' + esc(n.title) + '</b><small>' + esc(n.detail) + '</small></div>'
                + (n.due ? '<span class="due">' + esc(fmtDue(n.due)) + '</span>' : '') + (n.route ? '<i class="fa-solid fa-up-right-from-square" style="opacity:.5;font-size:11px;margin-left:6px"></i>' : '') + '</div>';
        }).join('');
        if (list.length > top.length) h += '<div class="wd-ln-more" style="cursor:pointer" onclick="document.getElementById(\'wdBellBtn\').click()">+' + (list.length - top.length) + ' việc khác… (bấm xem tất cả)</div>';
        return h;
    }
    // Bấm 1 nhắc việc trong widget -> mở cửa sổ liên quan (giống panel chuông); không route -> mở panel chuông.
    window.wdLnGo = function (route) { if (route) { try { window.wdOpenApp(route, metaOf(route.split('#')[0])); } catch (e) { } } else { var b = document.getElementById('wdBellBtn'); if (b) b.click(); } };

    // ---------- Flyout LỊCH VẠN NIÊN khi bấm đồng hồ taskbar ----------
    // Lưới tháng: ô hiện ngày DƯƠNG lớn + ngày ÂM nhỏ; chọn/rê ngày -> panel chi tiết
    // (âm lịch, can-chi ngày/tháng/năm, giờ hoàng đạo, tốt/xấu). Tính âm lịch CHỈ khi mở/đổi tháng.
    var calOffset = 0, calSel = null; // calSel: {d,m,y} ngày đang chọn
    function detailHtml(dd, mm, yy) {
        var f = LUNAR.info(dd, mm, yy), p = function (n) { return (n < 10 ? '0' : '') + n; };
        var lt = f.lunar;
        var q = f.quality;
        var html = '<div class="wd-cf-detail">';
        html += '<div class="wd-cf-dh"><span class="dl">' + DOW[new Date(yy, mm - 1, dd).getDay()] + ', ' + p(dd) + '/' + p(mm) + '/' + yy + '</span>'
            + '<span class="qa ' + (q.good ? 'good' : (q.bad ? 'bad' : 'mid')) + '">' + q.label + '</span></div>';
        html += '<div class="wd-cf-am">Âm lịch: <b>' + lt.day + '/' + lt.month + (lt.leap ? ' (nhuận)' : '') + '/' + lt.year + '</b></div>';
        html += '<div class="wd-cf-cc"><span>Ngày <b>' + f.ccDay + '</b></span><span>Tháng <b>' + f.ccMonth + '</b></span><span>Năm <b>' + f.ccYear + '</b></span></div>';
        html += '<div class="wd-cf-hd"><i class="fa-solid fa-sun"></i> Giờ hoàng đạo: <span>' + (f.hours.length ? f.hours.join(', ') : 'Không') + '</span></div>';
        html += '<div class="wd-cf-tx"><i class="fa-solid ' + (q.good ? 'fa-circle-check' : (q.bad ? 'fa-triangle-exclamation' : 'fa-circle-info')) + '"></i> ' + esc(q.reason) + '</div>';
        html += '</div>';
        return html;
    }
    function buildCalFlyout() {
        var fo = document.getElementById('wdCalFlyout'); if (!fo) return;
        var now = new Date(), p = function (n) { return (n < 10 ? '0' : '') + n; };
        var base = new Date(now.getFullYear(), now.getMonth() + calOffset, 1);
        var y = base.getFullYear(), mo = base.getMonth();
        var first = new Date(y, mo, 1).getDay(), dim = new Date(y, mo + 1, 0).getDate();
        var names = ['CN', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7'], thisMonth = (calOffset === 0);
        var html = '<div class="wd-cf-now"><div class="wd-cf-time">' + p(now.getHours()) + ':' + p(now.getMinutes()) + '</div><div class="wd-cf-date">' + DOW[now.getDay()] + ', ' + p(now.getDate()) + '/' + p(now.getMonth() + 1) + '/' + now.getFullYear() + '</div></div>';
        html += '<div class="wd-cf-nav"><span data-nav="-1"><i class="fa-solid fa-chevron-left"></i></span><b>Tháng ' + (mo + 1) + '/' + y + '</b><span data-nav="1"><i class="fa-solid fa-chevron-right"></i></span></div>';
        html += '<table class="wd-cf-vn"><thead><tr>'; names.forEach(function (n) { html += '<th>' + n + '</th>'; }); html += '</tr></thead><tbody><tr>';
        var col = 0, i;
        for (i = 0; i < first; i++) { html += '<td class="oth"></td>'; col++; }
        for (var day = 1; day <= dim; day++) {
            if (col === 7) { html += '</tr><tr>'; col = 0; }
            var lun = LUNAR.convertSolar2Lunar(day, mo + 1, y, 7);
            var lbl = (lun.day === 1) ? (lun.day + '/' + lun.month) : lun.day; // mùng 1 hiện cả tháng âm
            var isToday = thisMonth && day === now.getDate();
            var isSel = calSel && calSel.d === day && calSel.m === (mo + 1) && calSel.y === y;
            html += '<td class="vn' + (isToday ? ' today' : '') + (isSel ? ' sel' : '') + '" data-d="' + day + '" data-m="' + (mo + 1) + '" data-y="' + y + '">'
                + '<span class="sol">' + day + '</span><span class="lun">' + lbl + '</span></td>';
            col++;
        }
        while (col > 0 && col < 7) { html += '<td class="oth"></td>'; col++; }
        html += '</tr></tbody></table>';
        // Panel chi tiết cho ngày đang chọn (mặc định: hôm nay)
        var sel = calSel || { d: now.getDate(), m: now.getMonth() + 1, y: now.getFullYear() };
        html += detailHtml(sel.d, sel.m, sel.y);
        fo.innerHTML = html;
        Array.prototype.forEach.call(fo.querySelectorAll('[data-nav]'), function (s) { s.addEventListener('click', function (e) { e.stopPropagation(); calOffset += parseInt(s.getAttribute('data-nav'), 10); buildCalFlyout(); }); });
        Array.prototype.forEach.call(fo.querySelectorAll('td.vn'), function (td) {
            function pick(e) {
                e.stopPropagation();
                calSel = { d: +td.getAttribute('data-d'), m: +td.getAttribute('data-m'), y: +td.getAttribute('data-y') };
                Array.prototype.forEach.call(fo.querySelectorAll('td.vn.sel'), function (x) { x.classList.remove('sel'); });
                td.classList.add('sel');
                var old = fo.querySelector('.wd-cf-detail'); if (old) { var tmp = document.createElement('div'); tmp.innerHTML = detailHtml(calSel.d, calSel.m, calSel.y); old.parentNode.replaceChild(tmp.firstChild, old); }
            }
            td.addEventListener('click', pick);
            td.addEventListener('mouseenter', pick);
        });
    }
    window.wdOpenCalendar = function () {
        var fo = document.getElementById('wdCalFlyout');
        calOffset = 0; calSel = null; buildCalFlyout(); fo.classList.add('open');
        document.getElementById('wdLauncher').classList.remove('open'); document.getElementById('wdWallPanel').classList.remove('open'); document.getElementById('wdWgPanel').classList.remove('open');
    };
    document.getElementById('wdClock').style.cursor = 'pointer';
    document.getElementById('wdClock').addEventListener('click', function (e) {
        e.stopPropagation();
        var fo = document.getElementById('wdCalFlyout');
        if (fo.classList.contains('open')) { fo.classList.remove('open'); return; }
        window.wdOpenCalendar();
    });

    // ---------- Nút Back (trình duyệt) -> quản lý cửa sổ desktop, không rời app ----------
    function topWinRoute() {
        var best = null, bz = -1;
        Object.keys(wins).forEach(function (r) { var s = wins[r]; if (s.min) return; var z = parseInt(s.el.style.zIndex) || 0; if (z >= bz) { bz = z; best = r; } });
        return best;
    }
    function handleBack() {
        var r = topWinRoute();
        if (!r) return; // không còn cửa sổ -> ở lại desktop (không back trình duyệt)
        var s = wins[r];
        if (s.navDepth > 0) {
            s.navDepth--;
            try { s.el.querySelector('iframe').contentWindow.history.back(); return; } catch (e) { }
        }
        closeWin(r); // đang ở form đầu của cửa sổ -> đóng cửa sổ đó
    }
    try { history.pushState({ wd: 1 }, ''); } catch (e) { }
    window.addEventListener('popstate', function () { handleBack(); try { history.pushState({ wd: 1 }, ''); } catch (e) { } });

    applyTheme(); applyWall(); reloadCustoms().then(function () { applyWall(); }); syncSlideUI(); startSlide(); renderIcons(); renderLauncher(); renderWidgets(); tick(); setInterval(tick, 20000); loadReportGroups();
    // Quyền truy cập (gating menu theo người dùng) — fail-open nếu endpoint chưa sẵn sàng.
    loadPermissions();
    // Menu động: nạp cấu hình từ DB (nếu có) -> ghi đè danh sách module/chức năng; lỗi/rỗng -> giữ mặc định.
    loadMenuConfig();
    // Mỗi lần MỞ APP (đăng nhập): coi mọi thông báo là CHƯA ĐỌC -> badge luôn hiện SỐ + nhắc lại.
    notiRead = {}; try { lsSet('notiRead.' + USER, notiRead); } catch (e) { }
    // Thông báo/nhắc việc: nạp khi vào app -> đặt badge chuông + bật toast nhắc khi đăng nhập.
    loadNoti().then(function (list) {
        list = list || [];
        var od = list.filter(function (n) { return n.overdue; });
        if (od.length) {
            wdToast({
                type: 'overdue', icon: 'fa-bell',
                title: od.length + ' việc QUÁ HẠN cần xử lý',
                detail: od[0].title + ' — ' + od[0].detail + (od.length > 1 ? ' (+' + (od.length - 1) + ' việc khác)' : ''),
                timeout: 14000,
                onClick: function () { toggleNotiPanel(true); }
            });
        } else if (list.length) {
            // Không có quá hạn nhưng có nhắc việc -> toast nhẹ thông báo.
            wdToast({
                type: 'info', icon: 'fa-bell',
                title: 'Bạn có ' + list.length + ' nhắc việc',
                detail: list[0].title + ' — ' + list[0].detail + (list.length > 1 ? ' (+' + (list.length - 1) + ' việc khác)' : ''),
                timeout: 10000,
                onClick: function () { toggleNotiPanel(true); }
            });
        }
    });
    // Làm mới thông báo định kỳ (5 phút) để badge luôn đúng khi để app mở lâu.
    setInterval(function () { loadNoti(); }, 300000);
    // Heartbeat presence: báo "đang online" mỗi 60s kể cả khi user không thao tác (cửa sổ online 5').
    function presencePing() { try { fetch('/api/presence/ping', { method: 'POST', credentials: 'same-origin', headers: { 'Accept': 'application/json' } }).catch(function () { }); } catch (e) { } }
    presencePing(); setInterval(presencePing, 60000);
    // ===== Thời gian giữ đăng nhập theo MÁY (localStorage) — server cho tối đa 1 năm =====
    // Mặc định 1 năm (ít phiền nhất). User có thể đặt ngắn hơn cho máy dùng chung; hết hạn -> tự đăng xuất.
    setupSessionTimeout();
    window.addEventListener('resize', function () { renderIcons(); applySplitRatio(); refreshSplitPair(); fitTaskbar(); });
    // Trước khi rời trang: đẩy ngay cấu hình (vị trí cửa sổ...) lên server, tránh mất lần lưu cuối.
    window.addEventListener('beforeunload', function () { try { flushPush(); } catch (e) { } });
}

// ===== Thời gian giữ đăng nhập theo MÁY (per-device, localStorage) =====
var SS_DUR = 'wd.sessionMaxMs';      // thời lượng user chọn (ms) — theo máy
var SS_START = 'wd.sessionStartAt';  // mốc bắt đầu phiên trên máy này (ms)
var SS_MAX = 365 * 24 * 3600 * 1000; // trần 1 năm
function ssGetDur() { var v = parseInt(localStorage.getItem(SS_DUR)); if (!v || isNaN(v)) v = SS_MAX; return Math.min(Math.max(v, 300000), SS_MAX); }
function ssStart() { try { var s = parseInt(localStorage.getItem(SS_START)); if (!s || isNaN(s)) { s = Date.now(); localStorage.setItem(SS_START, '' + s); } return s; } catch (e) { return Date.now(); } }
function ssClear() { try { localStorage.removeItem(SS_START); } catch (e) { } }
function ssEnforce() { if ((Date.now() - ssStart()) > ssGetDur()) { ssClear(); location.href = '/Login/Logout'; return true; } return false; }
window.dangXuatSach = function () { ssClear(); if (typeof DangXuat === 'function') { try { DangXuat(); return; } catch (e) { } } location.href = '/Login/Logout'; };
function setupSessionTimeout() {
    // CSS popup chọn thời gian (tiêm 1 lần).
    if (!document.getElementById('wdSsCss')) {
        var st = document.createElement('style'); st.id = 'wdSsCss';
        st.textContent =
            '.wd-ss-overlay{position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:100000;display:flex;align-items:center;justify-content:center;}'
            + '.wd-ss-box{background:#fff;border-radius:10px;min-width:340px;max-width:92%;box-shadow:0 14px 44px rgba(0,0,0,.4);overflow:hidden;font-size:14px;}'
            + '.wd-ss-h{padding:12px 16px;background:#0a6c5e;color:#fff;font-weight:700;}'
            + '.wd-ss-note{padding:10px 16px 0;color:#666;font-size:12px;}'
            + '.wd-ss-opts{display:flex;flex-wrap:wrap;gap:8px;padding:12px 16px;}'
            + '.wd-ss-opt{padding:7px 12px;border:1px solid #cfd8d6;border-radius:6px;background:#f6f9f8;cursor:pointer;}'
            + '.wd-ss-opt:hover{border-color:#0a6c5e;}.wd-ss-opt.on{background:#0a6c5e;color:#fff;border-color:#0a6c5e;}'
            + '.wd-ss-foot{padding:0 16px 14px;text-align:right;}.wd-ss-cancel{padding:6px 14px;border:1px solid #cfd8d6;border-radius:6px;background:#fff;cursor:pointer;}'
            + 'html[data-theme="dark"] .wd-ss-box{background:#1c1c20;color:#eef0f3;}html[data-theme="dark"] .wd-ss-opt{background:#26262b;border-color:#3a3a42;color:#eef0f3;}'
            + 'html[data-theme="dark"] .wd-ss-cancel{background:#26262b;border-color:#3a3a42;color:#eef0f3;}';
        document.head.appendChild(st);
    }
    // Vào từ trang đăng nhập (đăng nhập MỚI) -> reset mốc phiên để khỏi bị đẩy ra ngay
    // khi SS_START cũ đã quá hạn (vd sau khi server restart/hết phiên rồi login lại).
    try { if (/\/login\/?$/i.test(document.referrer || '')) localStorage.setItem(SS_START, '' + Date.now()); } catch (e) { }
    ssStart(); ssEnforce(); setInterval(ssEnforce, 60000);
    document.addEventListener('visibilitychange', function () { if (!document.hidden) ssEnforce(); });
}
window.chonThoiGianDangNhap = function () {
    var presets = [['1 giờ', 3600e3], ['8 giờ', 8 * 3600e3], ['1 ngày', 24 * 3600e3], ['3 ngày', 3 * 24 * 3600e3], ['1 tuần', 7 * 24 * 3600e3], ['1 tháng', 30 * 24 * 3600e3], ['3 tháng', 90 * 24 * 3600e3], ['1 năm', SS_MAX]];
    var cur = ssGetDur();
    var ov = document.createElement('div'); ov.className = 'wd-ss-overlay';
    var btns = presets.map(function (p) { return '<button class="wd-ss-opt' + (Math.abs(p[1] - cur) < 1000 ? ' on' : '') + '" data-ms="' + p[1] + '">' + p[0] + '</button>'; }).join('');
    ov.innerHTML = '<div class="wd-ss-box"><div class="wd-ss-h"><i class="fa-solid fa-clock"></i> Thời gian giữ đăng nhập (máy này)</div>'
        + '<div class="wd-ss-note">Hết thời gian này sẽ tự đăng xuất. Lưu riêng theo từng máy. Tối đa 1 năm.</div>'
        + '<div class="wd-ss-opts">' + btns + '</div>'
        + '<div class="wd-ss-foot"><button class="wd-ss-cancel">Đóng</button></div></div>';
    document.body.appendChild(ov);
    function close() { if (ov.parentNode) ov.parentNode.removeChild(ov); }
    ov.addEventListener('mousedown', function (e) { if (e.target === ov) close(); });
    ov.querySelector('.wd-ss-cancel').addEventListener('click', close);
    ov.querySelectorAll('.wd-ss-opt').forEach(function (b) {
        b.addEventListener('click', function () {
            var ms = parseInt(b.getAttribute('data-ms'));
            try { localStorage.setItem(SS_DUR, '' + ms); localStorage.setItem(SS_START, '' + Date.now()); } catch (e) { }
            close();
            if (typeof wdToast === 'function') wdToast({ type: 'ok', icon: 'fa-clock', title: 'Đã đặt thời gian giữ đăng nhập', detail: b.textContent, timeout: 4000 });
        });
    });
};

// ===== Hydrate cấu hình desktop TỪ SERVER theo user, rồi mới khởi động desktop =====
(function () {
    var USER = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(hdUser ?? "user"));
    // Khôi phục ảnh nền tùy biến vào IndexedDB (cùng store mà wdBoot dùng).
    function restoreWalls(walls) {
        if (!walls || !walls.length) return Promise.resolve();
        return new Promise(function (res) {
            var rq = indexedDB.open('wdWalls_' + USER, 1);
            rq.onupgradeneeded = function () { var d = rq.result; if (!d.objectStoreNames.contains('imgs')) d.createObjectStore('imgs', { keyPath: 'id', autoIncrement: true }); };
            rq.onerror = function () { res(); };
            rq.onsuccess = function () {
                var db = rq.result;
                try {
                    var tx = db.transaction('imgs', 'readwrite'), st = tx.objectStore('imgs');
                    // Chỉ nạp khi store rỗng (tránh nhân đôi ảnh sau mỗi lần load).
                    var cnt = st.count();
                    cnt.onsuccess = function () {
                        if (cnt.result > 0) { res(); return; }
                        walls.forEach(function (w) { try { st.put(w); } catch (e) { } });
                    };
                    tx.oncomplete = function () { res(); };
                    tx.onerror = function () { res(); };
                } catch (e) { res(); }
            };
        });
    }
    function applyServer(json) {
        if (!json) return Promise.resolve();
        var cfg; try { cfg = JSON.parse(json); } catch (e) { return Promise.resolve(); }
        if (!cfg || !cfg.ls) return Promise.resolve();
        try {
            // Xóa các key wd.* cũ ở máy này rồi nạp cấu hình của user từ server.
            var rm = [];
            for (var i = 0; i < localStorage.length; i++) { var k = localStorage.key(i); if (k && k.indexOf('wd.') === 0) rm.push(k); }
            rm.forEach(function (k) { localStorage.removeItem(k); });
            Object.keys(cfg.ls).forEach(function (k) { try { localStorage.setItem(k, cfg.ls[k]); } catch (e) { } });
        } catch (e) { }
        return restoreWalls(cfg.walls);
    }
    function start() { try { wdBoot(); } catch (e) { console && console.error && console.error(e); } }
    fetch('/api/desktop/config', { credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
        .then(function (r) { return r.json(); })
        .then(function (d) { return applyServer(d && d.code === 0 ? d.data : null); })
        .then(start)
        .catch(start);
})();
</script>
