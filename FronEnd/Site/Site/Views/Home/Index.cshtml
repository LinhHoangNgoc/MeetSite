    // ---------- Shortcut icons ----------
    function renderIcons() {
        var host = document.getElementById('wdIcons'); host.innerHTML = '';
        var routes = (pinDesk || []).filter(function (r, i, a) { return a.indexOf(r) === i; })
            .filter(function (r) { return !modByRoute[r] || moduleVisible(r); }); // ẩn pin của module không được cấp quyền
        // Lưới đồng nhất + CHỐNG ĐÈ: mỗi icon chiếm 1 ô; vị trí đã lưu là "ưu tiên", nếu ô bị chiếm thì dời sang ô trống.
        var CW = ICON_CELL_W, CH = ICON_CELL_H, PAD = ICON_PAD;
        var rowsPerCol = Math.max(1, Math.floor((desktop.clientHeight - PAD * 2) / CH));
        var occ = {};
        function freeCell(c0, r0) {
            for (var c = c0; c < c0 + 80; c++) {
                for (var r = (c === c0 ? r0 : 0); r < rowsPerCol; r++) {
                    if (!occ[c + ':' + r]) { occ[c + ':' + r] = 1; return { c: c, r: r }; }
                }
            }
            occ[c0 + ':' + r0] = 1; return { c: c0, r: r0 };
        }
        routes.forEach(function (r, i) {
            var mm = metaOf(r), m = { route: r, title: mm.title, icon: mm.icon, accent: mm.accent };
            var pos = positions[r], pc, pr;
            if (pos) {
                pc = Math.max(0, Math.round((pos.x - PAD) / CW));
                pr = Math.max(0, Math.min(rowsPerCol - 1, Math.round((pos.y - PAD) / CH)));
            } else { pc = Math.floor(i / rowsPerCol); pr = i % rowsPerCol; }
            var cell = freeCell(pc, pr);
            var x = PAD + cell.c * CW, y = PAD + cell.r * CH;
            var el = document.createElement('button');
            el.className = 'wd-shortcut'; el.style.left = x + 'px'; el.style.top = y + 'px'; el.style.setProperty('--accent', m.accent);
            el.innerHTML = '<i class="fa-solid ' + m.icon + '"></i><span>' + esc(m.title) + '</span>';
            host.appendChild(el); bindShortcut(el, m);
        });
    }
