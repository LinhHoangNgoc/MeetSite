    // ---------- Lưới canh (grid snap) cho biểu tượng & widget ----------
    // Biểu tượng bám lưới ô 104×104px (rộng hơn icon 96px để KHÔNG đè nhau); widget bám lưới thô 20px.
    var ICON_CELL_W = 104, ICON_CELL_H = 104, ICON_PAD = 14;
    var WG_GRID = 20;
    function snapToGrid(v, cell, pad) { pad = pad || 0; return Math.round((v - pad) / cell) * cell + pad; }
    function snapIconPos(x, y) {
        var maxX = Math.max(0, desktop.clientWidth - 100), maxY = Math.max(0, desktop.clientHeight - 100);
        return {
            x: Math.max(0, Math.min(maxX, snapToGrid(x, ICON_CELL_W, ICON_PAD))),
            y: Math.max(0, Math.min(maxY, snapToGrid(y, ICON_CELL_H, ICON_PAD)))
        };
    }
    function snapWgPos(x, y) {
        var maxX = Math.max(0, desktop.clientWidth - 60), maxY = Math.max(0, desktop.clientHeight - 40);
        return {
            x: Math.max(0, Math.min(maxX, snapToGrid(x, WG_GRID, 0))),
